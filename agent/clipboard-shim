#!/usr/bin/env python3
"""AGS sandbox clipboard shim for wl-paste/wl-copy compatible calls."""

import base64
import json
import os
import socket
import subprocess
import sys

SOCK_ENV = "AGS_CLIPBOARD_SOCK"
DEFAULT_MIME = "text/plain;charset=utf-8"


def fallback(argv):
    name = os.path.basename(argv[0])
    target = f"/usr/bin/{name}"
    if os.path.exists(target) and os.access(target, os.X_OK):
        os.execv(target, [target] + argv[1:])
    print(f"{name}: AGS clipboard bridge unavailable", file=sys.stderr)
    return 1


def request(payload):
    sock_path = os.environ.get(SOCK_ENV)
    if not sock_path:
        raise RuntimeError("AGS_CLIPBOARD_SOCK is not set")
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
        sock.connect(sock_path)
        sock.sendall(json.dumps(payload).encode("utf-8") + b"\n")
        data = b""
        while not data.endswith(b"\n"):
            chunk = sock.recv(65536)
            if not chunk:
                break
            data += chunk
    if not data:
        raise RuntimeError("empty clipboard bridge response")
    response = json.loads(data.decode("utf-8"))
    if not response.get("ok"):
        raise RuntimeError(response.get("error", "clipboard bridge request failed"))
    return response


def parse_common(args):
    mime = None
    list_types = False
    passthrough = []
    i = 0
    while i < len(args):
        arg = args[i]
        if arg in ("-l", "--list-types"):
            list_types = True
        elif arg in ("-t", "--type"):
            i += 1
            if i >= len(args):
                raise RuntimeError(f"{arg} requires a MIME type")
            mime = args[i]
        elif arg.startswith("--type="):
            mime = arg.split("=", 1)[1]
        elif arg in ("-n", "--no-newline"):
            pass
        elif arg in ("--primary", "--seat", "--watch", "--paste-once", "--trim-newline", "--foreground", "--clear"):
            passthrough.append(arg)
        elif arg == "--help":
            print("AGS wl-clipboard shim: supports --list-types, --type/-t, text/image read and write")
            sys.exit(0)
        else:
            # Preserve compatibility by ignoring wl-clipboard options this shim
            # does not need for pi's paste/copy paths.
            passthrough.append(arg)
        i += 1
    return mime, list_types, passthrough


def wl_paste(argv):
    mime, list_types, _ = parse_common(argv[1:])
    if list_types:
        response = request({"v": 1, "op": "list"})
        sys.stdout.write("\n".join(response.get("types", [])))
        if response.get("types"):
            sys.stdout.write("\n")
        return 0
    response = request({"v": 1, "op": "read", "mime": mime})
    data = base64.b64decode(response.get("data_b64", ""))
    sys.stdout.buffer.write(data)
    sys.stdout.buffer.flush()
    return 0


def wl_copy(argv):
    mime, _, _ = parse_common(argv[1:])
    data = sys.stdin.buffer.read()
    request({
        "v": 1,
        "op": "write",
        "mime": mime or DEFAULT_MIME,
        "data_b64": base64.b64encode(data).decode("ascii"),
    })
    return 0


def main(argv):
    if not os.environ.get(SOCK_ENV):
        return fallback(argv)
    name = os.path.basename(argv[0])
    try:
        if name.endswith("wl-paste"):
            return wl_paste(argv)
        if name.endswith("wl-copy"):
            return wl_copy(argv)
        raise RuntimeError(f"unsupported shim name: {name}")
    except Exception as exc:
        print(f"{name}: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
