#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
ROOT_DIR="$(cd "$BIN_DIR/.." && pwd)"

CONFIG_FILE="${PI_SBOX_CONFIG_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/pi-sandbox/config.toml}"
RESOLVER="$ROOT_DIR/scripts/resolve-config.py"

for required in python3 jq; do
  if ! command -v "$required" >/dev/null 2>&1; then
    echo "Missing required dependency: $required" >&2
    exit 1
  fi
done

if ! CONFIG_JSON="$(python3 "$RESOLVER" --config "$CONFIG_FILE")"; then
  exit 1
fi

cfg() {
  jq -r "$1" <<<"$CONFIG_JSON"
}

AUTH_KEY="$(cfg '.sandbox.auth_key')"
SIGN_KEY="$(cfg '.sandbox.sign_key')"

generate_key_if_missing() {
  local key_path="$1"
  local comment="$2"
  if [[ -f "$key_path" ]]; then
    return
  fi

  mkdir -p "$(dirname "$key_path")"
  echo "Generating $key_path"
  ssh-keygen -t ed25519 -a 64 -f "$key_path" -C "$comment"
}

generate_key_if_missing "$AUTH_KEY" "pi-sandbox-auth"
generate_key_if_missing "$SIGN_KEY" "pi-sandbox-signing"

printf '\nAdd these public keys to GitHub:\n\n'
printf 'Auth key (SSH key for git push):\n'
cat "$AUTH_KEY.pub"
printf '\n\nSigning key (SSH signing key):\n'
cat "$SIGN_KEY.pub"
printf '\n\n'

if ! command -v secret-tool >/dev/null 2>&1; then
  cat <<'EOF'
secret-tool not found; skipping secret-store setup.
You can still provide secrets via environment variables at runtime.
EOF
  exit 0
fi

printf 'Optional: store configured secrets in keyring now.\n'
printf 'Press Enter on empty prompt to skip an env var.\n\n'

mapfile -t SECRET_ENVS < <(jq -r '.secrets[].env' <<<"$CONFIG_JSON" | sort -u)

for env_name in "${SECRET_ENVS[@]}"; do
  read -r -s -p "$env_name: " value
  echo

  if [[ -z "$value" ]]; then
    echo "Skipped $env_name"
    continue
  fi

  mapfile -t SECRET_STORE_SPECS < <(jq -c --arg env "$env_name" '.secrets[] | select(.env == $env and .source == "secret-tool") | .attributes' <<<"$CONFIG_JSON")
  if [[ ${#SECRET_STORE_SPECS[@]} -eq 0 ]]; then
    echo "No secret_store configured for $env_name (env-only)."
    continue
  fi

  for attrs_json in "${SECRET_STORE_SPECS[@]}"; do
    store_args=()
    while IFS=$'\t' read -r key attr_value; do
      store_args+=("$key" "$attr_value")
    done < <(jq -r 'to_entries[] | "\(.key)\t\(.value)"' <<<"$attrs_json")

    if [[ ${#store_args[@]} -eq 0 ]]; then
      continue
    fi

    printf '%s' "$value" | secret-tool store --label="pis $env_name" "${store_args[@]}"
    echo "Stored $env_name via secret-store attributes: $(jq -c '.' <<<"$attrs_json")"
  done
done

cat <<'EOF'

Setup complete.

Next steps:
1) Add auth key as GitHub SSH key.
2) Add signing key as GitHub SSH signing key.
3) Run: pis doctor
4) Start: pis (or pisb for browser mode)
EOF
