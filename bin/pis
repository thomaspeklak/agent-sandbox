#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SELF_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

case "${1:-}" in
  doctor)
    shift
    exec "$SELF_DIR/pis-doctor" "$@"
    ;;
  setup)
    shift
    exec "$SELF_DIR/pis-setup" "$@"
    ;;
  browser)
    shift
    exec "$SELF_DIR/pisb" "$@"
    ;;
  update)
    shift
    exec "$SELF_DIR/pis-update" "$@"
    ;;
  install)
    shift
    exec "$SELF_DIR/../scripts/install.sh" "$@"
    ;;
  uninstall)
    shift
    exec "$SELF_DIR/../scripts/uninstall.sh" "$@"
    ;;
esac

exec "$SELF_DIR/pis-run" "$@"
