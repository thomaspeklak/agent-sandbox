#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
ROOT_DIR="$(cd "$BIN_DIR/.." && pwd)"

CONFIG_FILE="${PI_SBOX_CONFIG_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/pi-sandbox/config.toml}"
RESOLVER="$ROOT_DIR/scripts/resolve-config.py"

ok_count=0
warn_count=0
fail_count=0

if [[ -t 1 ]]; then
  C_OK=$'\033[32m'
  C_WARN=$'\033[33m'
  C_FAIL=$'\033[31m'
  C_HEAD=$'\033[36m'
  C_RESET=$'\033[0m'
else
  C_OK=""
  C_WARN=""
  C_FAIL=""
  C_HEAD=""
  C_RESET=""
fi

section() {
  printf "\n%s== %s ==%s\n" "$C_HEAD" "$1" "$C_RESET"
}

ok() {
  ok_count=$((ok_count + 1))
  printf "%s[OK]%s %s\n" "$C_OK" "$C_RESET" "$1"
}

warn() {
  warn_count=$((warn_count + 1))
  printf "%s[WARN]%s %s\n" "$C_WARN" "$C_RESET" "$1"
}

fail() {
  fail_count=$((fail_count + 1))
  printf "%s[FAIL]%s %s\n" "$C_FAIL" "$C_RESET" "$1"
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

check_required_cmd() {
  local cmd="$1"
  if has_cmd "$cmd"; then
    ok "binary available: $cmd"
  else
    fail "missing required binary: $cmd"
  fi
}

check_optional_cmd() {
  local cmd="$1"
  if has_cmd "$cmd"; then
    ok "optional binary available: $cmd"
  else
    warn "optional binary missing: $cmd"
  fi
}

secret_exists_with_attrs() {
  local attrs_json="$1"
  if ! has_cmd secret-tool; then
    return 1
  fi

  local lookup_args=()
  while IFS=$'\t' read -r key value; do
    lookup_args+=("$key" "$value")
  done < <(jq -r 'to_entries[] | "\(.key)\t\(.value)"' <<<"$attrs_json")

  if [[ ${#lookup_args[@]} -eq 0 ]]; then
    return 1
  fi

  local value
  value="$(secret-tool lookup "${lookup_args[@]}" 2>/dev/null || true)"
  [[ -n "$value" ]]
}

section "Tooling"
check_required_cmd podman
check_required_cmd git
check_required_cmd ssh-keygen
check_required_cmd ssh-add
check_required_cmd bash
check_required_cmd python3
check_required_cmd jq
check_optional_cmd secret-tool
check_optional_cmd curl

section "Config"
if [[ -f "$CONFIG_FILE" ]]; then
  ok "config file present: $CONFIG_FILE"
else
  fail "missing config file: $CONFIG_FILE"
fi

if [[ -f "$RESOLVER" ]]; then
  ok "config resolver present: $RESOLVER"
else
  fail "missing config resolver: $RESOLVER"
fi

CONFIG_JSON=""
if [[ -f "$CONFIG_FILE" && -f "$RESOLVER" ]]; then
  if CONFIG_JSON="$(python3 "$RESOLVER" --config "$CONFIG_FILE" 2>/dev/null)"; then
    ok "config parsed successfully"
  else
    fail "config parsing failed: $CONFIG_FILE"
  fi
fi

cfg() {
  jq -r "$1" <<<"$CONFIG_JSON"
}

if [[ -n "$CONFIG_JSON" ]]; then
  IMAGE="$(cfg '.sandbox.image')"
  CONTAINERFILE="$(cfg '.sandbox.containerfile')"
  SANDBOX_PI_DIR="$(cfg '.sandbox.sandbox_pi_dir')"
  GITCFG_PATH="$(cfg '.sandbox.gitconfig_path')"
  AUTH_KEY="$(cfg '.sandbox.auth_key')"
  SIGN_KEY="$(cfg '.sandbox.sign_key')"
  CACHE_DIR="$(cfg '.sandbox.cache_dir')"
  AGENT_ENV="$CACHE_DIR/ssh-agent.env"

  if [[ -f "$CONTAINERFILE" ]]; then
    ok "Containerfile present: $CONTAINERFILE"
  else
    fail "missing Containerfile: $CONTAINERFILE"
  fi

  if [[ -f "$SANDBOX_PI_DIR/settings.json" ]]; then
    ok "sandbox settings present: $SANDBOX_PI_DIR/settings.json"
  else
    fail "missing sandbox settings: $SANDBOX_PI_DIR/settings.json"
  fi

  if [[ -f "$SANDBOX_PI_DIR/extensions/guard.ts" ]]; then
    ok "guard extension present: $SANDBOX_PI_DIR/extensions/guard.ts"
  else
    fail "missing guard extension: $SANDBOX_PI_DIR/extensions/guard.ts"
  fi

  if [[ -f "$GITCFG_PATH" ]]; then
    ok "git signing config present: $GITCFG_PATH"

    gpg_format="$(git config -f "$GITCFG_PATH" --get gpg.format 2>/dev/null || true)"
    gpg_sign="$(git config -f "$GITCFG_PATH" --get commit.gpgsign 2>/dev/null || true)"
    signing_key="$(git config -f "$GITCFG_PATH" --get user.signingkey 2>/dev/null || true)"

    [[ "$gpg_format" == "ssh" ]] && ok "git signing format is SSH" || warn "git signing format is not SSH in $GITCFG_PATH"
    [[ "$gpg_sign" == "true" ]] && ok "commit signing enabled in sandbox git config" || warn "commit signing not forced in sandbox git config"
    [[ "$signing_key" == "/home/dev/.ssh/pi-agent-signing.pub" ]] && ok "sandbox git signing key path configured" || warn "unexpected signing key path in $GITCFG_PATH: ${signing_key:-<unset>}"
  else
    warn "git signing config missing (created on first run): $GITCFG_PATH"
  fi

  section "Integrations"
  mapfile -t TOOL_SPECS < <(cfg '.tools[]? | @base64')
  if [[ ${#TOOL_SPECS[@]} -eq 0 ]]; then
    warn "no tools configured in [[tool]]"
  fi

  for encoded in "${TOOL_SPECS[@]}"; do
    tool_json="$(printf '%s' "$encoded" | base64 -d)"
    name="$(jq -r '.name' <<<"$tool_json")"
    path="$(jq -r '.path' <<<"$tool_json")"
    optional="$(jq -r '.optional' <<<"$tool_json")"

    if [[ -x "$path" ]]; then
      ok "tool '$name' binary present: $path"
    elif [[ "$optional" == "true" ]]; then
      warn "optional tool '$name' missing: $path"
    else
      fail "required tool '$name' missing or not executable: $path"
    fi
  done

  mapfile -t ALWAYS_MOUNTS < <(jq -c '.mounts[]? | select(.when == "always")' <<<"$CONFIG_JSON")
  for mount_json in "${ALWAYS_MOUNTS[@]}"; do
    host_path="$(jq -r '.host' <<<"$mount_json")"
    mode="$(jq -r '.mode' <<<"$mount_json")"
    kind="$(jq -r '.kind' <<<"$mount_json")"
    create="$(jq -r '.create' <<<"$mount_json")"
    optional="$(jq -r '.optional' <<<"$mount_json")"
    source="$(jq -r '.source' <<<"$mount_json")"

    if [[ -e "$host_path" ]]; then
      ok "mount source present ($source): $host_path"
      if [[ "$mode" == "rw" ]]; then
        if [[ "$kind" == "dir" ]]; then
          [[ -w "$host_path" ]] && ok "rw mount is writable: $host_path" || warn "rw mount not writable: $host_path"
        else
          [[ -w "$host_path" ]] && ok "rw file mount is writable: $host_path" || warn "rw file mount not writable: $host_path"
        fi
      fi
    elif [[ "$create" == "true" ]]; then
      warn "mount source missing but will be created on run ($source): $host_path"
    elif [[ "$optional" == "true" ]]; then
      warn "optional mount source missing ($source): $host_path"
    else
      fail "required mount source missing ($source): $host_path"
    fi
  done

  section "Container image/runtime"
  if podman image exists "$IMAGE"; then
    ok "image exists: $IMAGE"
    if podman run --rm --pull=never "$IMAGE" pi --version >/dev/null 2>&1; then
      ok "container runtime smoke test passed"
    else
      fail "container smoke test failed (image exists but pi did not start)"
    fi
  else
    warn "image not built yet: $IMAGE (run 'pis --version' once to build)"
  fi

  section "Keys & ssh-agent"
  if [[ -s "$AUTH_KEY" ]]; then
    ok "auth private key present: $AUTH_KEY"
  elif [[ -f "$AUTH_KEY" ]]; then
    warn "auth private key is empty: $AUTH_KEY (rerun 'pis setup')"
  else
    warn "auth private key missing: $AUTH_KEY (run 'pis setup')"
  fi

  if [[ -s "$AUTH_KEY.pub" ]]; then
    ok "auth public key present: $AUTH_KEY.pub"
  elif [[ -f "$AUTH_KEY.pub" ]]; then
    warn "auth public key is empty: $AUTH_KEY.pub (rerun 'pis setup')"
  else
    warn "auth public key missing: $AUTH_KEY.pub"
  fi

  if [[ -s "$SIGN_KEY" ]]; then
    ok "signing private key present: $SIGN_KEY"
  elif [[ -f "$SIGN_KEY" ]]; then
    warn "signing private key is empty: $SIGN_KEY (rerun 'pis setup')"
  else
    warn "signing private key missing: $SIGN_KEY (run 'pis setup')"
  fi

  if [[ -s "$SIGN_KEY.pub" ]]; then
    ok "signing public key present: $SIGN_KEY.pub"
  elif [[ -f "$SIGN_KEY.pub" ]]; then
    warn "signing public key is empty: $SIGN_KEY.pub (rerun 'pis setup')"
  else
    warn "signing public key missing: $SIGN_KEY.pub"
  fi

  agent_sock=""
  agent_pid=""
  if [[ -f "$AGENT_ENV" ]]; then
    while IFS='=' read -r k v; do
      case "$k" in
        SSH_AUTH_SOCK) agent_sock="$v" ;;
        SSH_AGENT_PID) agent_pid="$v" ;;
      esac
    done < "$AGENT_ENV"
  fi

  if [[ -n "$agent_sock" && -n "$agent_pid" && -S "$agent_sock" ]] && kill -0 "$agent_pid" 2>/dev/null; then
    ok "dedicated pis ssh-agent appears active"

    listed_keys="$(SSH_AUTH_SOCK="$agent_sock" ssh-add -L 2>/dev/null || true)"
    auth_pub="$(cat "$AUTH_KEY.pub" 2>/dev/null || true)"
    sign_pub="$(cat "$SIGN_KEY.pub" 2>/dev/null || true)"

    if [[ -n "$auth_pub" ]]; then
      grep -qxF "$auth_pub" <<<"$listed_keys" && ok "auth key loaded in dedicated ssh-agent" || warn "auth key not loaded in dedicated ssh-agent"
    fi
    if [[ -n "$sign_pub" ]]; then
      grep -qxF "$sign_pub" <<<"$listed_keys" && ok "signing key loaded in dedicated ssh-agent" || warn "signing key not loaded in dedicated ssh-agent"
    fi
  else
    warn "dedicated pis ssh-agent not active yet (normal before first 'pis' run)"
  fi

  section "Secrets"
  mapfile -t SECRET_ENVS < <(jq -r '.secrets[].env' <<<"$CONFIG_JSON" | sort -u)
  if [[ ${#SECRET_ENVS[@]} -eq 0 ]]; then
    warn "no secrets configured"
  fi

  for env_name in "${SECRET_ENVS[@]}"; do
    if [[ -n "${!env_name:-}" ]]; then
      ok "$env_name available via environment"
      continue
    fi

    found=0
    mapfile -t SECRET_FOR_ENV < <(jq -c --arg env "$env_name" '.secrets[] | select(.env == $env)' <<<"$CONFIG_JSON")
    for spec_json in "${SECRET_FOR_ENV[@]}"; do
      source_type="$(jq -r '.source' <<<"$spec_json")"
      case "$source_type" in
        env)
          from_env="$(jq -r '.from_env' <<<"$spec_json")"
          if [[ -n "${!from_env:-}" ]]; then
            ok "$env_name available via source env var: $from_env"
            found=1
            break
          fi
          ;;
        secret-tool)
          attrs_json="$(jq -c '.attributes' <<<"$spec_json")"
          if secret_exists_with_attrs "$attrs_json"; then
            ok "$env_name found in keyring with attributes: $(jq -c '.' <<<"$attrs_json")"
            found=1
            break
          fi
          ;;
      esac
    done

    if [[ "$found" == "0" ]]; then
      warn "$env_name not found in configured sources"
    fi
  done

  section "Sessions / resume"
  if [[ -d "$SANDBOX_PI_DIR" && -w "$SANDBOX_PI_DIR" ]]; then
    ok "sandbox pi dir is writable: $SANDBOX_PI_DIR"
  else
    fail "sandbox pi dir missing or not writable: $SANDBOX_PI_DIR"
  fi

  if [[ -d "$SANDBOX_PI_DIR/sessions" ]]; then
    ok "sessions directory present (resume ready): $SANDBOX_PI_DIR/sessions"
  else
    warn "sessions directory not created yet (will appear after first session)"
  fi

  if [[ -f "$SANDBOX_PI_DIR/auth.json" ]]; then
    ok "sandbox auth.json present"
  else
    warn "sandbox auth.json missing (login once inside pis if needed)"
  fi

  section "Browser sidecar (optional)"
  browser_enabled="$(cfg '.browser.enabled')"
  if [[ "$browser_enabled" == "true" ]]; then
    browser_cmd="$(cfg '.browser.command')"
    browser_port="$(cfg '.browser.debug_port')"

    if [[ "$browser_cmd" == */* ]]; then
      [[ -x "$browser_cmd" ]] && ok "browser command is executable: $browser_cmd" || warn "browser command not executable: $browser_cmd"
    else
      if command -v "$browser_cmd" >/dev/null 2>&1; then
        ok "browser command available: $browser_cmd"
      else
        warn "browser command not found in PATH: $browser_cmd"
      fi
    fi

    if has_cmd curl && curl -fsS "http://127.0.0.1:${browser_port}/json/version" >/dev/null 2>&1; then
      ok "browser debug endpoint reachable on localhost:${browser_port}"
    else
      warn "browser debug endpoint not running (normal until browser mode start)"
    fi

    browser_skill="$(cfg '.browser.pi_skill_path // empty')"
    if [[ -n "$browser_skill" ]]; then
      ok "browser pi skill path configured: $browser_skill"
    else
      warn "browser pi skill path is empty; browser tooling skill won't auto-load"
    fi
  else
    warn "browser integration disabled in config"
  fi
fi

printf "\n%sSummary:%s %s%d ok%s, %s%d warnings%s, %s%d failures%s\n" \
  "$C_HEAD" "$C_RESET" \
  "$C_OK" "$ok_count" "$C_RESET" \
  "$C_WARN" "$warn_count" "$C_RESET" \
  "$C_FAIL" "$fail_count" "$C_RESET"

if (( fail_count > 0 )); then
  exit 1
fi

exit 0
